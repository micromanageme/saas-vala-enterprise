# SaaS Vala Enterprise - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE - SUPABASE POSTGRESQL
# ============================================================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres"

# ============================================================================
# AUTHENTICATION - JWT
# ============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ============================================================================
# SESSION MANAGEMENT
# ============================================================================
SESSION_SECRET="your-session-secret-change-in-production"
SESSION_MAX_AGE="604800000"
SESSION_COOKIE_NAME="saas_vala_session"

# ============================================================================
# SECURITY
# ============================================================================
BCRYPT_ROUNDS="12"
CSRF_SECRET="your-csrf-secret-change-in-production"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000"

# ============================================================================
# API
# ============================================================================
API_VERSION="v1"
API_BASE_URL="http://localhost:3000/api"
API_RATE_LIMIT="1000"

# ============================================================================
# SUPABASE
# ============================================================================
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME="SaaS Vala Enterprise"
APP_URL="http://localhost:3000"
APP_ENV="development"

# ============================================================================
# OBSERVABILITY
# ============================================================================
LOG_LEVEL="debug"
CORRELATION_ID_HEADER="x-correlation-id"

# ============================================================================
# EMAIL
# ============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ============================================================================
# STORAGE
# ============================================================================
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
