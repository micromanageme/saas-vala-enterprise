# SaaS Vala Enterprise - Environment Configuration
# Copy this file to .env.local for local development

# ============================================================================
# DATABASE - SUPABASE POSTGRESQL
# ============================================================================
# Get your database password from: https://supabase.com/dashboard/project/svdjnytyjdjvtfjcupnx/settings/database
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# ============================================================================
# AUTHENTICATION - JWT
# ============================================================================
JWT_SECRET="saas-vala-enterprise-jwt-secret-key-2024-production-ready-secure-token-min-32-chars"
JWT_REFRESH_SECRET="saas-vala-enterprise-refresh-secret-key-2024-production-ready-secure-token-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ============================================================================
# SESSION MANAGEMENT
# ============================================================================
SESSION_SECRET="saas-vala-enterprise-session-secret-2024-production-ready-secure-token-min-32-chars"
SESSION_MAX_AGE="604800000" # 7 days in milliseconds
SESSION_COOKIE_NAME="saas_vala_session"

# ============================================================================
# SECURITY
# ============================================================================
BCRYPT_ROUNDS="12"
CSRF_SECRET="saas-vala-enterprise-csrf-secret-2024-production-ready-secure-token-min-32-chars"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000" # 15 minutes in milliseconds

# ============================================================================
# API
# ============================================================================
API_VERSION="v1"
API_BASE_URL="http://localhost:3000/api"
API_RATE_LIMIT="1000"

# ============================================================================
# SUPABASE
# ============================================================================
SUPABASE_URL="https://svdjnytyjdjvtfjcupnx.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_2OOiGvEYGVr6LbxkQil3Vg_1bhlZfj_"
# Add your service role key in production for admin operations
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME="SaaS Vala Enterprise"
APP_URL="http://localhost:3000"
APP_ENV="development"

# ============================================================================
# OBSERVABILITY
# ============================================================================
LOG_LEVEL="debug"
CORRELATION_ID_HEADER="x-correlation-id"

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ============================================================================
# STORAGE (Optional - for file uploads)
# ============================================================================
STORAGE_TYPE="local" # or "s3", "supabase"
STORAGE_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
